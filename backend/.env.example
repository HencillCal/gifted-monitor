PORT=3000

# Database
# postgresql://user:pass@host:5432/db
DATABASE_URL=

# Auth
JWT_SECRET=change-this-to-a-long-random-string
SESSION_SECRET=another-long-random-string

# Resend (email) — add up to 5 domains for round-robin sending
# Get domains + API keys from https://resend.com
RESEND1_API_KEY=re_...
RESEND1_DOMAIN=alerts.yourdomain.com
RESEND2_API_KEY=
RESEND2_DOMAIN=
RESEND3_API_KEY=
RESEND3_DOMAIN=
RESEND4_API_KEY=
RESEND4_DOMAIN=
RESEND5_API_KEY=
RESEND5_DOMAIN=

# App URL (used for verification/reset links in emails)
FRONTEND_URL=https://monitor.yourdomain.com

# Monitoring engine
PING_CHECK_INTERVAL_SECS=10
MIN_PING_INTERVAL_MINS=1

# Timezone for timestamps
TIMEZONE=Africa/Nairobi

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://monitor.yourdomain.com,http://localhost:5173
